// Copy to main/secrets.h (gitignored) and fill in for local dev. Production devices receive
// these via NVS at provisioning (see app_config.h precedence).
#pragma once

#define WIFI_SSID     "my-network"
#define WIFI_PASSWORD "my-password"

// The assigned agent (hermes-sandbox bridge, PR #347). The bearer is the instance's
// AGENTKEYS_BRIDGE_TOKEN; leave empty to talk to a bridge running in unauthenticated dev mode.
#define AGENT_BASE_URL "https://<instance>.<vefaas-gateway>"
#define AGENT_BEARER   ""
#define BROKER_URL     "https://broker.<zone>"
