# AgentKeys operator-workstation env file — TEMPLATE (public).
#
# This is the placeholder template published to the open-source mirror so a
# fork operator can see the exact deploy SHAPE. The real, value-filled file is
# `scripts/operator-workstation.env` (kept in the private monorepo, never
# published). To stand up your own deployment:
#
#   cp scripts/operator-workstation.env.example scripts/operator-workstation.env
#   # edit the four REPLACE_ME inputs below — everything else derives from them
#   set -a; source ./scripts/operator-workstation.env; set +a
#
# Scope: shell vars used by AWS admin tooling + the demo walkthrough. The broker
# process itself reads NONE of these — they exist for `aws s3 ls`,
# `aws sts assume-role-with-web-identity`, and other workstation-side admin
# commands that need to address YOUR AWS account.
#
# NOTE: `scripts/operator-workstation.env` is gitignored in this mirror so your
# real values are never accidentally committed.

# ─── The four inputs you supply (everything below derives from these) ─────────

# Your 12-digit AWS account id (owns the agentkeys-* roles + buckets).
ACCOUNT_ID=000000000000

# AWS region for STS + S3 + SES.
REGION=us-east-1
AWS_REGION=$REGION
AWS_DEFAULT_REGION=$REGION

# Your broker's public hostname. Also the OIDC issuer host (must match the URL
# passed to `aws iam create-open-id-connect-provider --url` byte-for-byte).
BROKER_HOST=broker.example.invalid

# Parent DNS zone owning BROKER_HOST + MAIL_DOMAIN + the worker subdomains, and
# its Route 53 hosted-zone id (discover with
# `aws route53 list-hosted-zones --query 'HostedZones[?Name==\`'"$ZONE"'.\`].Id'`).
ZONE=example.invalid
PARENT_ZONE_ID=ZXXXXXXXXXXXXX

# ─── Derived: OIDC ────────────────────────────────────────────────────────────
OIDC_ISSUER=https://${BROKER_HOST}
OIDC_PROVIDER_ARN=arn:aws:iam::${ACCOUNT_ID}:oidc-provider/${BROKER_HOST}

# ─── Derived: per-data-class IAM roles (one role per bucket, arch.md §17.2) ───
DATA_ROLE_ARN=arn:aws:iam::${ACCOUNT_ID}:role/agentkeys-data-role
VAULT_ROLE_ARN=arn:aws:iam::${ACCOUNT_ID}:role/agentkeys-vault-role
MEMORY_ROLE_ARN=arn:aws:iam::${ACCOUNT_ID}:role/agentkeys-memory-role
CONFIG_ROLE_ARN=arn:aws:iam::${ACCOUNT_ID}:role/agentkeys-config-role

# ─── Derived: per-data-class S3 buckets (separate blast radius per class) ─────
VAULT_BUCKET=agentkeys-vault-${ACCOUNT_ID}
MEMORY_BUCKET=agentkeys-memory-${ACCOUNT_ID}
CONFIG_BUCKET=agentkeys-config-${ACCOUNT_ID}
MAIL_BUCKET=agentkeys-mail-${ACCOUNT_ID}
BUCKET=${MAIL_BUCKET}

# ─── Derived: signer (co-located with the broker today; own hostname so it can
#     migrate to its own machine without an API change) ───────────────────────
SIGNER_HOST=signer.${BROKER_HOST#*.}
AGENTKEYS_SIGNER_URL=https://${SIGNER_HOST}

# ─── Derived: service workers (per-data-class hostnames are the migration seam)
WORKER_AUDIT_HOST=audit.${BROKER_HOST#*.}
WORKER_EMAIL_HOST=email.${BROKER_HOST#*.}
WORKER_CRED_HOST=cred.${BROKER_HOST#*.}
WORKER_MEMORY_HOST=memory.${BROKER_HOST#*.}
WORKER_CONFIG_HOST=config.${BROKER_HOST#*.}
WORKER_CLASSIFY_HOST=classify.${BROKER_HOST#*.}
AGENTKEYS_WORKER_AUDIT_URL=https://${WORKER_AUDIT_HOST}
AGENTKEYS_WORKER_EMAIL_URL=https://${WORKER_EMAIL_HOST}
AGENTKEYS_WORKER_CRED_URL=https://${WORKER_CRED_HOST}
AGENTKEYS_WORKER_MEMORY_URL=https://${WORKER_MEMORY_HOST}
AGENTKEYS_WORKER_CONFIG_URL=https://${WORKER_CONFIG_HOST}
AGENTKEYS_WORKER_CLASSIFY_URL=https://${WORKER_CLASSIFY_HOST}

# ─── Derived: hosted MCP server ───────────────────────────────────────────────
MCP_HOST=mcp.${BROKER_HOST#*.}
AGENTKEYS_MCP_URL=https://${MCP_HOST}

# ─── SES sender ───────────────────────────────────────────────────────────────
# Your verified SES domain identity (the recipient root for inbound mail and the
# DKIM/SPF/DMARC domain). May differ from BROKER_HOST's parent zone.
MAIL_DOMAIN=bots.example.invalid
BROKER_EMAIL_FROM_ADDRESS=noreply@${MAIL_DOMAIN}

# ─── CLI session storage ──────────────────────────────────────────────────────
# Store the session JWT in a file instead of the OS keychain (keychain-free
# automated runs). Comment out + re-run `agentkeys init` to use the keychain.
AGENTKEYS_SESSION_STORE=file

# Contract addresses are NOT operator inputs — they live in the chain profile
# (crates/agentkeys-core/chain-profiles/<chain>.json), the machine-readable
# source of truth, and are written there by the chain bring-up. Do not paste
# literal addresses here.
